{
  "server": {
    "host": "0.0.0.0",
    "port": 8000
  },
  "frontend": {
    "build_dir": "frontend/dist",
    "dev_port": 5173
  },
  "qwen_vl": {
    "api_key": "",
    "base_url": "https://dashscope.aliyuncs.com/compatible-mode/v1",
    "model": "qwen-vl-max",
    "timeout_seconds": 30
  },
  "llm": {
    "base_url": "https://dashscope.aliyuncs.com/compatible-mode/v1",
    "api_key": "",
    "model": "qwen-plus",
    "temperature": 0.1,
    "max_tokens": 1024,
    "timeout_seconds": 30,
    "structured_output_method": "function_calling",
    "disable_parallel_tool_calls": true
  },
  "alibaba_ocr": {
    "access_key_id": "",
    "access_key_secret": "",
    "endpoint": "ocr-api.cn-hangzhou.aliyuncs.com",
    "timeout_seconds": 15
  },
  "pipeline": {
    "request_timeout_seconds": 60,
    "outputs_dir": "data/outputs",
    "samples_dir": "data/samples",
    "cleanup_after_response": true
  },
  "logging": {
    "level": "INFO",
    "format": "json",
    "request_id_header": "X-Request-ID",
    "log_dir": "data/logs",
    "log_file": "tuneai.log",
    "rotation": "10 MB",
    "retention": "7 days"
  }
}
