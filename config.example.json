{
  "server": {
    "host": "0.0.0.0",
    "port": 8000
  },
  "frontend": {
    "build_dir": "frontend/dist",
    "dev_port": 5173
  },
  "vision_llm": {
    "api_key": "",
    "base_url": "https://your-openai-compatible-endpoint/v1",
    "model": "your-vision-model",
    "timeout_seconds": 30
  },
  "llm": {
    "base_url": "https://your-openai-compatible-endpoint/v1",
    "api_key": "",
    "model": "your-text-model",
    "temperature": 0.1,
    "max_tokens": 1024,
    "timeout_seconds": 30
  },
  "ocr": {
    "provider": "aliyun",
    "config": {
      "access_key_id": "",
      "access_key_secret": "",
      "endpoint": "ocr-api.cn-hangzhou.aliyuncs.com",
      "timeout_seconds": 15
    }
  },
  "pipeline": {
    "request_timeout_seconds": 60,
    "outputs_dir": "data/outputs",
    "samples_dir": "data/samples",
    "cleanup_after_response": true
  },
  "logging": {
    "level": "INFO",
    "format": "json",
    "request_id_header": "X-Request-ID",
    "log_dir": "data/logs",
    "log_file": "tuneai.log",
    "rotation": "10 MB",
    "retention": "7 days"
  }
}
