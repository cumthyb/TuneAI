{
  "server": {
    "host": "0.0.0.0",
    "port": 8000
  },
  "frontend": {
    "build_dir": "frontend/dist",
    "dev_port": 5173
  },
  "provider_policy": {
    "default_provider": "glm"
  },
  "providers": {
    "glm": {
      "llm": {
        "api_key": "",
        "base_url": "",
        "model": "glm-4-plus",
        "temperature": 0.1,
        "max_tokens": 1024,
        "timeout_seconds": 30,
        "client_class": "langchain_openai.ChatOpenAI",
        "client_kwargs": {},
        "model_kwargs": {},
        "extra_body": {},
        "disable_parallel_tool_calls": false
      },
      "vision_llm": {
        "api_key": "",
        "base_url": "",
        "model": "glm-4v-plus",
        "timeout_seconds": 30,
        "client_class": "langchain_openai.ChatOpenAI",
        "client_kwargs": {},
        "model_kwargs": {},
        "extra_body": {}
      },
      "ocr": {
        "api_key": "",
        "base_url": "https://open.bigmodel.cn/api/paas/v4",
        "model": "glm-4v-plus",
        "timeout_seconds": 30,
        "max_tokens": 4096
      }
    },
    "qwen": {
      "llm": {
        "api_key": "",
        "base_url": "",
        "model": "qwen-plus",
        "temperature": 0.1,
        "max_tokens": 1024,
        "timeout_seconds": 30,
        "client_class": "langchain_openai.ChatOpenAI",
        "client_kwargs": {},
        "model_kwargs": {},
        "extra_body": {},
        "disable_parallel_tool_calls": false
      },
      "vision_llm": {
        "api_key": "",
        "base_url": "",
        "model": "qwen-vl-plus",
        "timeout_seconds": 30,
        "client_class": "langchain_openai.ChatOpenAI",
        "client_kwargs": {},
        "model_kwargs": {},
        "extra_body": {}
      },
      "ocr": {
        "api_key": "",
        "base_url": "https://dashscope.aliyuncs.com/compatible-mode/v1",
        "model": "qwen-vl-ocr-latest",
        "timeout_seconds": 30,
        "max_tokens": 4096
      }
    }
  },
  "pipeline": {
    "request_timeout_seconds": 60,
    "max_image_size_mb": 20,
    "outputs_dir": "data/outputs",
    "cleanup_after_response": true
  },
  "logging": {
    "level": "INFO",
    "format": "json",
    "log_dir": "data/logs",
    "log_file": "tuneai.log",
    "rotation": "10 MB",
    "retention": "7 days"
  }
}
