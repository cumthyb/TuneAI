{
  "server": {
    "host": "0.0.0.0",
    "port": 8000
  },
  "frontend": {
    "build_dir": "frontend/dist",
    "dev_port": 5173
  },
  "api_keys": {
    "openai": "",
    "anthropic": ""
  },
  "llm": {
    "model": "gpt-4o-mini",
    "base_url": "http://localhost:11434/v1",
    "api_key": "ollama",
    "temperature": 0.1,
    "max_tokens": 4096,
    "timeout_seconds": 30,
    "fallback_model": ""
  },
  "ocr": {
    "engine": "paddleocr",
    "use_gpu": false,
    "det_db_thresh": 0.3,
    "rec_batch_num": 6
  },
  "pipeline": {
    "request_timeout_seconds": 30,
    "input_dir": "data/outputs",
    "output_dir": "data/outputs",
    "samples_dir": "data/samples",
    "cleanup_after_response": true
  },
  "logging": {
    "level": "INFO",
    "format": "json",
    "request_id_header": "X-Request-ID",
    "log_dir": "data/logs",
    "log_file": "tuneai.log",
    "rotation": "10 MB",
    "retention": "7 days"
  }
}
