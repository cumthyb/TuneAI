    "autoprefixer": "^10.4.16",
    "eslint": "^8.57.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.4.32",
    "prettier": "^3.2.0",
    "sass": "^1.69.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
